SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password

# OpenRouter AI API
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
