# Flask
SECRET_KEY=change_me_in_production_use_random_32_chars

# MySQL Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=Laxit@#123
DB_NAME=roommate_matching
DB_PORT=3306

# JWT (use a long random string in production)
JWT_SECRET=super_secret_hostel_fallback_key_change_me

# Google OAuth 2.0
# Get from: https://console.developers.google.com/
